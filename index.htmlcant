                        </div>
                    </div>
                </div>
                <!-- 菜品分页按钮 共3页 -->
                <div class="dish-pagination">
                    <button class="dish-page-btn active" data-page="1">1</button>
                    <button class="dish-page-btn" data-page="2">2</button>
                    <button class="dish-page-btn" data-page="3">3</button>
                </div>
            </section>

            <!-- 评价 -->
            <section class="reviews-section" id="reviews">
                <h2 class="section-title">顾客<span>评价</span></h2>
                <div class="reviews-grid">
                    <div class="review-card">
                        <div class="stars">⭐⭐⭐⭐⭐</div>
                        <p class="review-text">菜品新鲜美味，配送速度非常快，包装精致。</p>
                        <div class="review-author">
                            <div class="author-avatar">
                                <img src="女1.jpg" /></div>
                            <div class="author-info"><div class="name">张女士</div></div>
                        </div>
                    </div>
                    <div class="review-card">
                        <div class="stars">⭐⭐⭐⭐⭐</div>
                        <p class="review-text">味道超赞，分量足，价格实惠，强烈推荐！</p>
                        <div class="review-author">
                            <div class="author-avatar">
                                <img src="女2.jpg" /></div>
                            <div class="author-info"><div class="name">李女士</div></div>
                        </div>
                 </div>
                    <div class="review-card">
                        <div class="stars">⭐⭐⭐⭐⭐</div>
                        <p class="review-text">环境优美 外酥里嫩 好吃不贵！</p>
                        <div class="review-author">
                            <div class="author-avatar">
                                <img src="男1.jpg" /></div>
                            <div class="author-info"><div class="name">王先生</div></div>
                        </div>
                    </div>
