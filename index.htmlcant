            <!-- 联系 -->
            <section class="contact-section" id="contact">
                <form class="contact-form">
                    <input type="text" placeholder="您的姓名">
                    <input type="email" placeholder="您的邮箱">
                    <input type="tel" placeholder="您的电话">
                    <textarea placeholder="请输入您的留言或建议..."></textarea>
                    <button type="submit" class="submit-btn">提交留言</button>
                </form>
            </section>
        </div>
    </div>

    <!-- 购物车弹窗 -->
    <div class="cart-modal" id="cartModal">
        <div class="cart-box">
            <div class="cart-title">
                <span>我的购物车</span>
                <span class="close-cart" onclick="closeCart()">×</span>
            </div>
            <div id="cartList"></div>
            <div class="cart-total">合计：¥<span id="cartTotal">0.00</span></div>
            <button class="checkout-btn" onclick="checkout()">结算订单</button>
        </div>
    </div>

    <!-- 底部分页 -->
    <div class="pagination">
        <button id="prevBtn">上一页</button>
        <span class="page-num">当前：第<span id="cur">1</span>页 / 共2页</span>
        <button id="nextBtn">下一页</button>
    </div>

    <!-- 页脚 -->
    <footer>
        <div class="footer-column">
            <h4>快速导航</h4>
            <ul>
                <li><a href="javascript:goPage(1)">首页</a></li>
                <li><a href="javascript:goPage(2)">菜品中心</a></li>
            </ul>
        </div>
        <div class="footer-column">
            <h4>个人中心</h4>
            <ul>
                <li><a href="#">我的订单</a></li>
                <li><a href="#">我的收藏</a></li>
            </ul>
        </div>
        <div class="footer-column">
            <h4>服务城市</h4>
            <ul>
                <li><a href="#">北京</a></li>
                <li><a href="#">上海</a></li>
            </ul>
        </div>
        <div class="footer-column">
            <h4>联系我们</h4>
            <p>400-888-9999</p>
            <p>service@meiwei.com</p>
        </div>
    </footer>

    <script>
        // 全局页面切换
        let nowPage = 1;
        const total = 2;
        function goPage(p){
            nowPage = p;
            document.querySelectorAll('.page').forEach(item=>item.classList.remove('active'));
            document.getElementById('page'+p).classList.add('active');
            updatePageBtn();
        }
        function updatePageBtn(){
            document.getElementById('cur').innerText = nowPage;
            document.getElementById('prevBtn').disabled = nowPage === 1;
            document.getElementById('nextBtn').disabled = nowPage === total;
        }
        document.getElementById('prevBtn').onclick = ()=>{if(nowPage>1)goPage(nowPage-1)};
        document.getElementById('nextBtn').onclick = ()=>{if(nowPage<total)goPage(nowPage+1)};
        updatePageBtn();

        // 菜品分页 3页切换
        let nowDishPage = 1;
        const totalDishPage = 3;
        document.querySelectorAll('.dish-page-btn').forEach(btn=>{
            btn.onclick = function(){
                let p = parseInt(this.dataset.page);
                nowDishPage = p;
                // 切换菜品页面
                document.querySelectorAll('.dishes-page').forEach(item=>item.classList.remove('active'));
                document.getElementById('dishPage'+p).classList.add('active');
                // 按钮高亮
                document.querySelectorAll('.dish-page-btn').forEach(b=>b.classList.remove('active'));
                this.classList.add('active');
            }
        })

        // 购物车
        let cart = [];
        document.getElementById('cartIcon').onclick = function(){
            renderCart();
            document.getElementById('cartModal').style.display = 'flex';
        }
        function closeCart(){
            document.getElementById('cartModal').style.display = 'none';
        }
        // 加入购物车
        document.querySelectorAll('.add-cart-btn').forEach(btn=>{
            btn.onclick = function(){
                const card = this.closest('.dish-card');
                const id = card.dataset.id;
                const name = card.dataset.name;
                const price = parseFloat(card.dataset.price);
                const img = card.dataset.img;
                let idx = cart.findIndex(v=>v.id===id);
                if(idx===-1){
                    cart.push({id,name,price,img,num:1});
                }else{
                    cart[idx].num++;
                }
                updateCartCount();
                alert(`${name} 已加入购物车`);
        }
        })
        function updateCartCount(){
            let count = 0;
            cart.forEach(v=>count+=v.num);
            document.getElementById('cartCount').innerText = count;
        }
        function renderCart(){
            let listDom = document.getElementById('cartList');
            let total = 0;
            if(cart.length===0){
                listDom.innerHTML = '<div class="cart-empty">购物车暂无商品</div>';
                document.getElementById('cartTotal').innerText = "0.00";
                return;
            }
            let html = "";
            cart.forEach(v=>{
                total += v.price * v.num;
            html += `
            <div class="cart-item">
                <div class="cart-item-img"><img src="${v.img}"></div>
                <div class="cart-item-info">
                    <div>${v.name}</div>
                    <div style="color:#ff6b81">¥${v.price.toFixed(2)}</div>
                </div>
                <div class="cart-item-num">
                    <button onclick="changeNum('${v.id}',-1)">-</button>
                    <span>${v.num}</span>
                    <button onclick="changeNum('${v.id}',1)">+</button>
                </div>
                <div onclick="delItem('${v.id}')" style="color:#999;cursor:pointer;margin-left:8px">删除</div>
            </div>`;
        });
        listDom.innerHTML = html;
        document.getElementById('cartTotal').innerText = total.toFixed(2);
        }
        function changeNum(id,n){
            let idx = cart.findIndex(v=>v.id===id);
            if(idx===-1)return;
            cart[idx].num += n;
            if(cart[idx].num <= 0) cart.splice(idx,1);
            updateCartCount();
            renderCart();
        }
        function delItem(id){
            let idx = cart.findIndex(v=>v.id===id);
            if(idx!==-1) cart.splice(idx,1);
            updateCartCount();
            renderCart();
        }
        function checkout(){
            if(cart.length===0){
                alert("购物车为空，无法结算！");
                return;
            }
            let allTotal = document.getElementById('cartTotal').innerText;
            if(confirm(`确认结算订单？\n合计金额：¥${allTotal}`)){
                alert("订单提交成功！感谢下单~");
        cart = [];
        updateCartCount();
        closeCart();
        }
        }
    </script>
</body>
</html>
