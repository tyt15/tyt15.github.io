                            <div class="dish-card" data-id="10" data-name="水果捞" data-price="18.9" data-img="https://via.placeholder.com/250x180?text=水果捞">
                                <div class="discount-tag">-8%</div>
                                <div class="dish-front">
                                    <div class="dish-img">
                                        <img src="水果捞.jpg" /></div>
                                    <div class="dish-info">
                                        <div class="dish-name">水果捞</div>
                                        <div class="price"><span class="current-price">¥18.9</span><span class="original-price">¥20.9</span></div>
                                        <button class="add-cart-btn">加入购物车</button>
                                    </div>
                                </div>
                                <div class="dish-back">
                                    <p>多种鲜果</p>
                                    <p>酸甜爽口</p>
                                    <button class="add-cart-btn" style="margin-top:15px">加入购物车</button>
                                </div>
                            </div>
                            <div class="dish-card" data-id="11" data-name="培根炒饭" data-price="24.9" data-img="https://via.placeholder.com/250x180?text=培根炒饭">
                                <div class="discount-tag">-6%</div>
                                <div class="dish-front">
                                    <div class="dish-img">
                                        <img src="炒饭.jpg" /></div>
                                    <div class="dish-info">
                                        <div class="dish-name">培根炒饭</div>
                                        <div class="price"><span class="current-price">¥24.9</span><span class="original-price">¥26.9</span></div>
                                        <button class="add-cart-btn">加入购物车</button>
                                    </div>
                                </div>
                                <div class="dish-back">
                                    <p>粒粒分明</p>
                                    <p>饱腹感十足</p>
                                    <button class="add-cart-btn" style="margin-top:15px">加入购物车</button>
                                </div>
                            </div>
                            <div class="dish-card" data-id="12" data-name="柠檬茶饮" data-price="9.9" data-img="https://via.placeholder.com/250x180?text=柠檬茶饮">
                                <div class="discount-tag">-5%</div>
                                <div class="dish-front">
                                    <div class="dish-img">
                                        <img src="柠檬茶.jpg" /></div>
                                    <div class="dish-info">
                                        <div class="dish-name">柠檬茶饮</div>
                                        <div class="price"><span class="current-price">¥9.9</span><span class="original-price">¥10.9</span></div>
                                        <button class="add-cart-btn">加入购物车</button>
                                    </div>
                                </div>
                                <div class="dish-back">
                                    <p>清爽解腻</p>
                                    <p>天然柠檬</p>
